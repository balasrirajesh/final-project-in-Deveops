extends layout

block content
    section.hero
        h1 My Favorite Songs
        p Your curated playlist (Stored In-Memory)
    
    if songs.length > 0
        section#songs-list.grid-layout
            each song in songs
                .song-card(data-id=song.id, data-audio=song.audio, data-title=song.name, data-artist=song.artist_name, data-image=song.image || 'https://via.placeholder.com/300')
                    .card-image-wrap
                        img(src=song.image || 'https://via.placeholder.com/300', alt=song.name)
                        button.play-btn: i.fas.fa-play
                    .card-content
                        h3= song.name
                        p= song.artist_name
                        .card-footer
                            button.like-btn.liked(data-id=song.id, title="Unlike"): i.fas.fa-heart
    else
        .empty-state
            i.fas.fa-heart-broken
            h2 No Favorites Yet
            p Go back to the #[a(href="/") Home Page] to discover some music!
